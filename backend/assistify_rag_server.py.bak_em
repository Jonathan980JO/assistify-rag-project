import chromadb
from sentence_transformers import SentenceTransformer
from backend.pdf_ingestion_rag import VectorStore

class LiveRAGManager:
    def __init__(self):
        # We enforce connection to the exact reindexed database and latest collection
        db_path = str(Path(__file__).resolve().parent / "chroma_db_v3")
        self.vs = VectorStore(persist_directory=db_path)
        
        client = chromadb.PersistentClient(path=db_path)
        collections = client.list_collections()
        if collections:
            candidate_names = sorted([c.name for c in collections if "support_docs_v3" in c.name], reverse=True)
            selected = None
            for col_name in candidate_names:
                try:
                    candidate = client.get_collection(col_name)
                    _probe = self.vs.collection
                    self.vs.collection = candidate
                    if candidate.count() > 0:
                        self.vs.search(query="probe", top_k=1, threshold=-2.0)
                    selected = candidate
                    print(f"[LiveRAGManager] Selected queryable collection: {col_name}")
                    break
                except Exception as probe_err:
                    print(f"[LiveRAGManager] Skipping broken collection '{col_name}': {probe_err}")
                    self.vs.collection = _probe
                    continue

            if selected is not None:
                self.vs.collection = selected
            
        self.doc_profile = self._build_doc_profile()

    def _build_doc_profile(self) -> dict:
        """Build dynamic document profile based on DB metadata, 100% topic agnostic."""
        profile = {
            "units": set(),
            "chapters": set(),
            "sections": set(),
            "filenames": set()
        }
        try:
            if not self.vs.collection: return profile
            res = self.vs.collection.get(include=["metadatas"])
            if not res or not res.get("metadatas"): return profile
            for meta in res["metadatas"]:
                if meta:
                    if "unit" in meta and meta["unit"]:
                        profile["units"].add(str(meta["unit"]).strip())
                    if "chapter" in meta and meta["chapter"]:
                        profile["chapters"].add(str(meta["chapter"]).strip())
                    if "section" in meta and meta["section"]:
                        profile["sections"].add(str(meta["section"]).strip())
                    if "source" in meta and meta["source"]:
                        profile["filenames"].add(str(meta["source"]).split("/")[-1])
        except Exception as e:
            print(f"[LiveRAGManager] Profile auto-build disabled/failed: {e}")
        return profile

        
    def search(self, query: str, top_k: int = 4, distance_threshold: float = 1.0, return_dicts: bool = False):
        import re

        def _safe_float(v, default=0.0):
            try:
                return float(v)
            except Exception:
                return default

        def _safe_int(v, default=0):
            try:
                return int(v)
            except Exception:
                return default

        def _source_name(item: dict) -> str:
            meta = item.get("metadata", {}) or {}
            return str(meta.get("source") or meta.get("filename") or "")

        def _is_noisy_chunk(item: dict) -> bool:
            txt = str(item.get("text", "") or "")
            if not txt or len(txt.strip()) < 40:
                return True
            lower = txt.lower()
            noise_signatures = [
                "70779c", "qxd:wiley", "ff fe", "obj<</", "| page ",
                "<script", "%53%45%4c", "charset=iso-8859", "line 1: incorrect syntax",
            ]
            if any(sig in lower for sig in noise_signatures):
                return True
            sample = txt[:1200]
            if sample:
                bad = sum(1 for ch in sample if not (ch.isalnum() or ch.isspace() or ch in ".,;:!?؟،-_'\"()[]{}%/"))
                if (bad / max(1, len(sample))) > 0.18:
                    return True
            return False

        def _prefer_dominant_source(items: list[dict], strict: bool) -> list[dict]:
            if not items:
                return items
            weights = {}
            for idx, it in enumerate(items):
                src = _source_name(it)
                if not src:
                    continue
                weights[src] = weights.get(src, 0.0) + (1.0 / (idx + 1))
            if not weights:
                return items
            ranked = sorted(weights.items(), key=lambda x: x[1], reverse=True)
            dominant_src, dominant_w = ranked[0]
            second_w = ranked[1][1] if len(ranked) > 1 else 0.0
            if strict or dominant_w >= (second_w * 1.3):
                kept = [it for it in items if _source_name(it) == dominant_src]
                if kept:
                    return kept
            return items

        def _normalize_query_for_retrieval(raw_query: str) -> str:
            """Generic intent + language normalizer for retrieval form. Topic-agnostic."""
            arabic_word_to_num = {
                "الأولى": "1",
                "الاولى": "1",
                "الثانية": "2",
                "الثالثة": "3",
                "الرابعة": "4",
                "الخامسة": "5",
                "السادسة": "6",
                "السابعة": "7",
                "الثامنة": "8",
                "التاسعة": "9",
                "العاشرة": "10",
            }

            # Convert Arabic-Indic digits to ASCII digits first.
            digit_map = str.maketrans("٠١٢٣٤٥٦٧٨٩", "0123456789")
            normalized = (raw_query or "").translate(digit_map)

            # Convert phrases like "الوحدة الأولى" or "الوحدة 1" to "Unit 1".
            arabic_unit_pattern = re.compile(
                r"الوحدة\s*(الأولى|الاولى|الثانية|الثالثة|الرابعة|الخامسة|السادسة|السابعة|الثامنة|التاسعة|العاشرة|\d+)",
                re.IGNORECASE,
            )

            # Convert phrases like "الفصل الأول" or "الفصل 1" to "Chapter 1".
            arabic_chapter_pattern = re.compile(
                r"الفصل\s*(الأول|الاول|الثاني|الثالث|الرابع|الخامس|السادس|السابع|الثامن|التاسع|العاشر|\d+)",
                re.IGNORECASE,
            )

            def _replace_unit(match: re.Match) -> str:
                token = (match.group(1) or "").strip()
                unit_num = arabic_word_to_num.get(token, token)
                return f"Unit {unit_num}"

            def _replace_chapter(match: re.Match) -> str:
                token = (match.group(1) or "").strip()
                chapter_map = {
                    "الأول": "1", "الاول": "1", "الثاني": "2", "الثالث": "3", "الرابع": "4",
                    "الخامس": "5", "السادس": "6", "السابع": "7", "الثامن": "8", "التاسع": "9", "العاشر": "10"
                }
                chapter_num = chapter_map.get(token, token)
                return f"Chapter {chapter_num}"

            normalized = arabic_unit_pattern.sub(_replace_unit, normalized)
            normalized = arabic_chapter_pattern.sub(_replace_chapter, normalized)

            # Normalize translated ordinal-English forms to canonical `Unit N`.
            ordinal_to_num = {
                "first": "1", "second": "2", "third": "3", "fourth": "4", "fifth": "5",
                "sixth": "6", "seventh": "7", "eighth": "8", "ninth": "9", "tenth": "10",
            }
            for ordinal, num in ordinal_to_num.items():
                normalized = re.sub(
                    rf"\b(?:the\s+)?{ordinal}\s+(unit|chapter)\b",
                    lambda m: f"{m.group(1).capitalize()} {num}",
                    normalized,
                    flags=re.IGNORECASE,
                )

            return normalized

        normalized_query = _normalize_query_for_retrieval(query)
        query_style = _analyze_query_style(query)
        contains_arabic_query = _contains_arabic(query)
        q_lower = normalized_query.lower()
        
        # Intent Detection
        is_summary = query_style["is_summary"] or any(kw in q_lower for kw in ['summar', 'overview', 'main points', 'whole book', '10-point summary', 'intro'])
        is_global_summary = any(kw in q_lower for kw in ['whole book', '10-point summary', 'entire book'])
        is_paragraph = any(kw in q_lower for kw in ['return the paragraph', 'quote the paragraph', 'return paragraph', 'paragraph about', 'فقرة'])
        is_compare = bool(query_style.get("is_compare"))
        is_list_like = bool(query_style.get("is_list"))
        is_definition = any(kw in q_lower for kw in ["what is", "definition", "تعريف", "ما هو", "ما هي"])
        
        # 1. Retrieval Depth (small, high-precision defaults)
        if is_paragraph:
            base_k = 3
        elif is_summary:
            base_k = 6
        elif is_compare:
            base_k = 5
        elif is_list_like:
            base_k = 5
        else:
            base_k = 4
        k = min(8, max(int(top_k or 0), base_k))

        retrieval_query = (query or "").strip() if contains_arabic_query else normalized_query
        if not retrieval_query:
            retrieval_query = normalized_query
        embedding_query_text = f"query: {retrieval_query.strip()}"
        print(f"[LiveRAGManager] Embedding Query Text: '{embedding_query_text}'")
        
        unit_match = re.search(r'unit\s*(\d+)', q_lower)
        chapter_match = re.search(r'chapter\s+(\d+)', q_lower)
        lesson_match = re.search(r'lesson\s*(\d+)', q_lower)
        target_unit_match = None
        target_section_match = None
        target_named_section = None
        target_lesson_match = lesson_match.group(1) if lesson_match else None
        
        # 3. Global Summary Mode
        if unit_match and not is_global_summary:
            target_unit_match = unit_match.group(1)
        if chapter_match and not is_global_summary:
            target_section_match = chapter_match.group(1)
            
        # 4. Check against dynamic doc profile for named sections
        if not target_unit_match and not target_section_match and not is_global_summary:
            if hasattr(self, 'doc_profile') and getattr(self, 'doc_profile', {}).get("sections"):
                # Sort sections by length desc to match longest first
                sorted_sections = sorted(self.doc_profile["sections"], key=len, reverse=True)
                for sec in sorted_sections:
                    if sec and len(sec) > 4 and sec.lower() in q_lower:
                        target_named_section = sec
                        break
            
        intent_str = "summary" if is_summary else ("paragraph" if is_paragraph else "factual")
        if is_global_summary: intent_str = "global summary"
            
        print(f"\n[LiveRAGManager] Original Query: '{query}'")
        print(f"[LiveRAGManager] Normalized Retrieval Query: '{normalized_query}'")
        print(f"[LiveRAGManager] Detected Intent: {intent_str} | k: {k}")
        if not is_summary:
            print(
                f"[RAG Guard Runtime] mode={RAG_GUARD_MODE_VERSION} "
                f"old_strict_0.7_active={RAG_OLD_STRICT_07_ACTIVE} "
                f"new_two_stage_mild_active={not RAG_OLD_STRICT_07_ACTIVE}"
            )
        if target_unit_match:
            print(f"[LiveRAGManager] Detected Unit: {target_unit_match}")
        if target_section_match:
            print(f"[LiveRAGManager] Detected Chapter: {target_section_match}")
        if target_named_section:
            print(f"[LiveRAGManager] Detected Named Section: {target_named_section}")
        print(f"[LiveRAGManager] Collection: {self.vs.collection.name}")
            
        results = []
        raw_retrieved_count = 0
        filtered_count = 0
            
        # Prioritize matching unit for unit-based queries
        if target_unit_match and not is_paragraph:
            search_query = retrieval_query.strip()
            if not search_query:
                search_query = "main concepts overview"

            def _is_toc_or_index_chunk(item: dict) -> bool:
                meta = item.get("metadata", {}) or {}
                section = str(meta.get("section", "")).lower()
                text = str(item.get("text", "")).lower()
                hay = f"{section}\n{text[:400]}"
                toc_terms = ["table of contents", "contents", "index", "toc"]
                if any(term in hay for term in toc_terms):
                    return True
                if re.search(r'\.{3,}\s*\d+', hay):
                    return True
                return False

            def _is_strong_unit_chunk(item: dict, unit_num: str) -> bool:
                meta = item.get("metadata", {}) or {}
                unit_ok = str(meta.get("unit", "")).strip() == str(unit_num)
                text = str(item.get("text", "")).strip()
                has_substance = len(text) >= 120
                return unit_ok and has_substance and (not _is_toc_or_index_chunk(item))

            raw_results = self.vs.search(query=search_query, top_k=max(k * 5, 50), threshold=-2.0, filter_meta=None)
            raw_retrieved_count = len(raw_results)
            print(f"[LiveRAGManager] Raw retrieved chunks BEFORE filtering: {raw_retrieved_count}")

            detected_unit = str(target_unit_match)
            filtered = [c for c in raw_results if str((c.get("metadata") or {}).get("unit", "")) == detected_unit]
            print(f"[RAG] Unit filter applied: {len(filtered)} chunks kept")

            if len(filtered) >= 3:
                print("[RAG] Strict unit filter applied: True")
                if is_summary:
                    strong_filtered = [c for c in filtered if _is_strong_unit_chunk(c, detected_unit)]
                    print(f"[RAG] Strong unit chunks: {len(strong_filtered)}")
                    results = strong_filtered if strong_filtered else filtered
                else:
                    results = filtered
                filtered_count = len(results)
                print(f"[LiveRAGManager] Chunks AFTER unit filtering: {filtered_count}")

                if is_summary:
                    def _safe_int(value, default=10**9):
                        try:
                            if value is None or value == "":
                                return default
                            return int(value)
                        except Exception:
                            return default

                    summary_terms = ["summary", "conclusion", "key points", "in brief", "overview"]
                    detail_terms = ["for example", "for instance", "case study", "exercise", "review questions", "mcq", "true/false", "fill in the blanks"]

                    before_toc_filter = len(results)
                    results = [r for r in results if not _is_toc_or_index_chunk(r)]
                    print(f"[LiveRAGManager] Unit summary TOC/index excluded: {before_toc_filter - len(results)}")

                    if results:
                        def _position(item: dict) -> int:
                            meta = item.get("metadata", {}) or {}
                            page_val = _safe_int(meta.get("page"), default=10**9)
                            if page_val != 10**9:
                                return page_val
                            return _safe_int(meta.get("chunk_index"), default=10**9)

                        positions = [_position(r) for r in results]
                        min_pos = min(positions) if positions else 0
                        max_pos = max(positions) if positions else 0
                        early_cutoff = min_pos + int((max_pos - min_pos) * 0.30)

                        scored = []
                        for r in results:
                            meta = r.get("metadata", {}) or {}
                            txt = str(r.get("text", ""))
                            lower_txt = txt.lower()
                            section = str(meta.get("section", "")).lower()

                            pos = _position(r)
                            is_early = pos <= early_cutoff
                            has_summary_cue = any(term in lower_txt[:500] or term in section for term in summary_terms)
                            has_detail_cue = any(term in lower_txt for term in detail_terms)

                            priority = 0.0
                            if has_summary_cue:
                                priority += 3.0
                            if is_early:
                                priority += 2.0
                            if not is_early and not has_summary_cue:
                                priority -= 1.5
                            if has_detail_cue and not has_summary_cue:
                                priority -= 0.8

                            base_sim = r.get("score", r.get("similarity", 0.0))
                            try:
                                priority += float(base_sim) * 0.2
                            except Exception:
                                pass

                            scored.append((priority, pos, r))

                        scored.sort(key=lambda x: (x[0], -x[1]), reverse=True)
                        results = [r for _, _, r in scored]
                        print(f"[LiveRAGManager] Unit summary prioritization: span={min_pos}-{max_pos}, early_cutoff={early_cutoff}, candidates={len(results)}")
                results = results[:k]
            else:
                if is_summary:
                    print("[RAG] Strict unit filter applied: False (relaxed unit-summary path)")
                    results = filtered if filtered else raw_results[:k]
                print("[RAG] Strict unit filter applied: False (fallback to unfiltered)")
                print("[LiveRAGManager] Unit filtering returned too few chunks. Falling back to unfiltered results.")
                if not is_summary:
                    results = raw_results[:k]

        # Prioritize matching chapter by passing filter_meta
        elif target_section_match or target_named_section:
            if target_section_match:
                search_query = re.sub(r'(?i)chapter\s+\d+', '', retrieval_query).strip()
            else:
                search_query = retrieval_query.replace(target_named_section.lower(), '', 1).strip()
                
            if not search_query: search_query = "main concepts overview"
            
            # Flexible matching for section
            all_docs = self.vs.collection.get(include=["metadatas"])
            target_sections = []
            if all_docs and all_docs.get("metadatas"):
                if target_section_match:
                    ch_pattern = re.compile(rf'chapter\s*0*{target_section_match}\b', re.IGNORECASE)
                    for m in all_docs["metadatas"]:
                        sec = str(m.get("section", ""))
                        if sec and ch_pattern.search(sec):
                            target_sections.append(sec)
                elif target_named_section:
                    target_sections = [target_named_section]
                target_sections = list(set(target_sections))
            
            valid_ids = set()
            min_page, max_page = -1, -1
            if target_sections:
                chapter_docs = self.vs.collection.get(where={"section": {"$in": target_sections}})
                if chapter_docs and chapter_docs['metadatas']:
                    pages = [m.get('page', -1) for m in chapter_docs['metadatas'] if m.get('page', -1) != -1]
                    if pages:
                        pages.sort()
                        clusters = []
                        current_cluster = [pages[0]]
                        for p in pages[1:]:
                            if p - current_cluster[-1] <= 20:
                                current_cluster.append(p)
                            else:
                                clusters.append(current_cluster)
                                current_cluster = [p]
                        clusters.append(current_cluster)
                        
                        true_cluster = max(clusters, key=len)
                        min_page, max_page = true_cluster[0], true_cluster[-1]
                        
                        for m, i in zip(chapter_docs['metadatas'], chapter_docs['ids']):
                            if min_page <= m.get('page', -1) <= max_page:
                                valid_ids.add(i)

            if is_summary and valid_ids:
                print("[LiveRAGManager] Chapter Summary Mode: Sampling evenly across chapter span.")
                import numpy as np
                
                docs_with_pages = [(m.get('page', 999), m.get('chunk_index', 0), m, t, i) 
                                   for m, t, i in zip(chapter_docs['metadatas'], chapter_docs['documents'], chapter_docs['ids']) 
                                   if i in valid_ids and t is not None]
                docs_with_pages.sort(key=lambda x: (x[0], x[1]))
                
                total_chunks = len(docs_with_pages)
                print(f"[LiveRAGManager] Chapter span: {min_page}-{max_page}, Total valid chunks: {total_chunks}")
                
                if total_chunks <= k:
                    sampled_docs = docs_with_pages
                else:
                    sampled_indices = np.linspace(0, total_chunks - 1, k, dtype=int)
                    sampled_indices = sorted(list(set(sampled_indices)))
                    sampled_docs = [docs_with_pages[idx] for idx in sampled_indices]
                
                results = [{"text": t, "metadata": m, "score": 0.0, "id": i} for _, _, m, t, i in sampled_docs]
                filtered_count = len(results)
                print(f"[LiveRAGManager] Sampled {filtered_count} representative chunks across the chapter.")
            else:
                # ---------------- REGULAR CHAPTER QUERY OR FALLBACK ----------------
                # Get multiple chunks to ensure we find enough inside bounds
                # Do NOT use filter_meta straight to vector search to avoid skipping chunks if exact match fails
                raw_results = self.vs.search(query=search_query, top_k=max(k * 5, 50), threshold=-2.0, filter_meta=None)
                raw_retrieved_count = len(raw_results)
                print(f"[LiveRAGManager] Raw retrieved chunks BEFORE filtering: {raw_retrieved_count}")
                
                # 3. Flexible Match Filtering
                for r in raw_results:
                    m = r.get("metadata", {})
                    page_val = m.get("page", -1)
                    sec_val = str(m.get("section", ""))
                    
                    is_in_chapter = False
                    if target_sections:
                        if sec_val in target_sections:
                            # Validate page cluster 
                            if valid_ids:
                                if min_page <= page_val <= max_page:
                                    is_in_chapter = True
                            else:
                                is_in_chapter = True
                    
                    if is_in_chapter:
                        results.append(r)
                
                filtered_count = len(results)
                print(f"[LiveRAGManager] Chunks AFTER chapter filtering: {filtered_count}")
                
                # 2. Fallback to global semantic search
                if filtered_count < 3:
                    print("[LiveRAGManager] Chapter filtering returned 0 or very few chunks. Falling back to semantic search globally.")
                    results = raw_results[:k]
                else:
                    results = results[:k]
        else:
            # 3. Global Summary Mode explicitly avoids filtering and uses larger k
            if is_global_summary:
                # Get chunks matching query, + some first page chunks as overview
                results = self.vs.search(query=retrieval_query, top_k=k, threshold=-2.0)
                first_pages = self.vs.search(query="table of contents overview introduction", top_k=5, threshold=-2.0)
                seen = {r["id"] for r in results if "id" in r} or {r["text"] for r in results}
                for r in first_pages:
                    if r.get("id") not in seen and r.get("text") not in seen:
                        results.insert(0, r)
                        seen.add(r.get("id") or r.get("text"))
            else:
                results = self.vs.search(query=retrieval_query, top_k=k, threshold=-2.0)
            
            raw_retrieved_count = len(results)
            print(f"[LiveRAGManager] Raw retrieved chunks BEFORE filtering: {raw_retrieved_count}")
            print(f"[LiveRAGManager] Chunks AFTER chapter filtering: {raw_retrieved_count} (no filter applied)")
            
        final_results = [r for r in results if r.get("text")]

        # Cross-encoder rerank pass (if available on VectorStore)
        if final_results and hasattr(self.vs, "reranker") and getattr(self.vs, "reranker", None):
            try:
                rr_pairs = [[retrieval_query, str(r.get("text", ""))] for r in final_results]
                rr_scores = self.vs.reranker.predict(rr_pairs)
                for item, rr in zip(final_results, rr_scores):
                    item["rerank_score"] = float(rr)
                final_results.sort(key=lambda x: x.get("rerank_score", -1e9), reverse=True)
                print("[LiveRAGManager] Reranked top chunks:")
                for idx, item in enumerate(final_results[:6]):
                    m = item.get("metadata", {}) or {}
                    print(
                        f"  [RR {idx}] rerank={item.get('rerank_score', 0.0):.4f} "
                        f"sim={_safe_float(item.get('similarity', item.get('score', 0.0))):.4f} "
                        f"page={m.get('page')} section={m.get('section')}"
                    )
            except Exception as rerank_err:
                print(f"[LiveRAGManager] Rerank skipped due to error: {rerank_err}")

        # Generic cleanup: drop clearly noisy/OCR-binary chunks when enough evidence exists.
        non_noisy = [r for r in final_results if not _is_noisy_chunk(r)]
        if len(non_noisy) >= max(3, min(6, k // 2)):
            final_results = non_noisy

        # Lesson/chapter lightweight rerank by explicit mention in section/text.
        if target_lesson_match:
            n = str(target_lesson_match)
            lesson_re = re.compile(rf"\blesson\s*0*{n}\b", re.IGNORECASE)
            scored = []
            matched = []
            for r in final_results:
                meta = r.get("metadata", {}) or {}
                section = str(meta.get("section", "") or "")
                txt = str(r.get("text", "") or "")[:1800]
                boost = 0.0
                if lesson_re.search(section) or lesson_re.search(txt):
                    boost += 0.45
                base = _safe_float(r.get("similarity", r.get("score", 0.0)))
                scored.append((base + boost, r))
                if boost > 0.0:
                    matched.append((base + boost, r))
            if matched:
                matched.sort(key=lambda x: x[0], reverse=True)
                final_results = [r for _, r in matched]
            else:
                scored.sort(key=lambda x: x[0], reverse=True)
                final_results = [r for _, r in scored]

        # Prefer source coherence for summaries and lesson-targeted prompts.
        if is_summary or target_lesson_match:
            final_results = _prefer_dominant_source(final_results, strict=False)

        final_results = final_results[:k]
        
        # 4. Paragraph Retrieval Fix: expand best chunk
        if is_paragraph and final_results:
            best_chunk = final_results[0]
            sec = best_chunk.get("metadata", {}).get("section")
            pg = best_chunk.get("metadata", {}).get("page")
            if sec and pg:
                nearby = self.vs.collection.get(where={"$and": [{"section": sec}, {"page": {"$gte": max(1, pg-1)}}, {"page": {"$lte": pg+1}}]})
                if nearby and nearby['documents']:
                    # Merge nearby docs visually
                    docs_with_ids = list(zip(nearby['ids'], nearby['metadatas'], nearby['documents']))
                    # sort by chunk index if possible, else page
                    docs_with_ids.sort(key=lambda x: (x[1].get('page', 0), x[1].get('chunk_index', 0)))
                    
                    import re
                    merged_docs = []
                    for _, _, t in docs_with_ids:
                        # Reconstruct clean text: remove broken line joins/hyphenation
                        clean_t = re.sub(r'-\n\s*', '', t) # fix hyphenation
                        clean_t = re.sub(r'(?<!\n)\n(?!\n)', ' ', clean_t) # remove single newlines (join lines)
                        clean_t = re.sub(r'\b(?:info|evaluating)\b', '', clean_t, flags=re.IGNORECASE)
                        clean_t = re.sub(r'\b[a-zA-Z]{1,2}\b', '', clean_t)
                        clean_t = re.sub(r'\s{2,}', ' ', clean_t).strip()
                        merged_docs.append(clean_t)

                    merged_text = " ".join(merged_docs)
                    merged_text = re.sub(r'\s{2,}', ' ', merged_text).strip()
                    if len(merged_text) > 5000:
                        merged_text = merged_text[:5000].rsplit(" ", 1)[0].strip()
                    
                    final_results = [{
                        "text": merged_text,
                        "metadata": best_chunk.get("metadata", {}),
                        "similarity": best_chunk.get("similarity", best_chunk.get("score", 0.0)),
                        "score": best_chunk.get("similarity", best_chunk.get("score", 0.0))
                    }]
        
        # Keep chunks separate (no aggressive merging) and de-duplicate by chunk id/text.
        if len(final_results) > 1 and not is_paragraph:
            deduped = []
            seen_keys = set()
            for item in final_results:
                meta = item.get("metadata", {}) or {}
                key = (
                    str(item.get("id", "")),
                    str(meta.get("source", meta.get("filename", ""))),
                    str(meta.get("page", "")),
                    str(meta.get("chunk_index", "")),
                    str(item.get("text", ""))[:180],
                )
                if key in seen_keys:
                    continue
                seen_keys.add(key)
                deduped.append(item)
            final_results = deduped

        # Hard cap for total context size to avoid giant polluted prompts.
        CONTEXT_CHAR_CAP = 9000
        if final_results:
            capped = []
            running_chars = 0
            for item in final_results:
                txt = str(item.get("text", ""))
                if not txt:
                    continue
                if running_chars + len(txt) > CONTEXT_CHAR_CAP and capped:
                    break
                capped.append(item)
                running_chars += len(txt)
            final_results = capped

        total_text_len = sum(len(r.get("text", "")) for r in final_results)
        print(f"[LiveRAGManager] Expanded/Merged into {len(final_results)} chunks (Merged context size: {total_text_len} chars)")

        if target_unit_match and is_summary:
            target_unit_str = str(target_unit_match)
            strong_chunks = sum(
                1
                for r in final_results
                if str((r.get("metadata", {}) or {}).get("unit", "")).strip() == target_unit_str
                and len(str(r.get("text", "")).strip()) >= 120
            )
            if strong_chunks < 2 and total_text_len < 800:
                print(
                    f"[RAG] Unit summary rejected: insufficient evidence "
                    f"(strong_chunks={strong_chunks}, total_context_chars={total_text_len})"
                )
                if return_dicts:
                    return []
                return []
        
        # 5. Add safeguard: if final context is empty or too small -> re-run retrieval with relaxed constraints
        if total_text_len < 200:
            print("[LiveRAGManager] Final context is too small! Relaxing constraints and re-running globally.")
            fallback_results = self.vs.search(query=retrieval_query, top_k=max(k, 5), threshold=-2.0)
            if fallback_results:
                final_results = [r for r in fallback_results if r.get("text")]
            else:
                final_results = []
            final_results = final_results[:max(k, 5)]
            total_text_len = sum(len(r.get("text", "")) for r in final_results)
            print(f"[LiveRAGManager] Fallback Global Chunks: {len(final_results)} (Total text length: {total_text_len})")

        def _safe_float(v, default=0.0):
            try:
                return float(v)
            except Exception:
                return default

        def _safe_int(v, default=0):
            try:
                return int(v)
            except Exception:
                return default

        # 6. Final Strict Relevance & Keyword Guards (Only apply to factual/paragraph searches)
        if not is_summary:
            import re
            
            # Deterministic sorting: sort final chunks consistently by relevance, then page, then chunk ID
            final_results.sort(key=lambda x: (
                -_safe_float(x.get("similarity", x.get("score", 0.0))),
                _safe_int((x.get("metadata") or {}).get("page", 0)),
                str(x.get("id", ""))
            ))
            
            # Build query concepts once for Stage-B consistency checks.
            stop_words = {'a', 'an', 'the', 'is', 'are', 'was', 'were', 'and', 'or', 'but', 'if', 'in', 'on', 'at', 'to', 'for', 'with', 'about', 'by', 'of', 'from', 'how', 'what', 'where', 'when', 'why', 'who', 'which', 'this', 'that', 'these', 'those', 'chapter', 'unit', 'summarize', 'summary', 'explain', 'describe', 'paragraph', 'points', 'bullet', 'main', 'overview', 'return', 'quote', 'steps', 'process'}
            query_words = [w for w in re.split(r'\W+', q_lower) if len(w) > 2 and w not in stop_words and not w.isdigit()]
            if contains_arabic_query:
                query_words = []

            # Stage A (mild filtering): avoid hard global 0.70 cutoff for factual/paragraph queries.
            strict_cutoff = max(float(distance_threshold), 0.0)
            if contains_arabic_query:
                mild_cutoff = -0.05 if is_paragraph else 0.02
            else:
                mild_cutoff = -0.10 if is_paragraph else 0.10
            filtered_by_score = [
                r for r in final_results
                if _safe_float(r.get("similarity", r.get("score", 0.0))) >= mild_cutoff
            ]
            pre_stage_results = list(final_results)

            # Borderline salvage for valid in-domain queries: keep top candidates for Stage-B validation.
            if not filtered_by_score and final_results:
                top_sim = _safe_float(final_results[0].get("similarity", final_results[0].get("score", 0.0)))
                if top_sim >= max(0.12, mild_cutoff - 0.06):
                    filtered_by_score = final_results[:max(2, min(3, len(final_results)))]

            # Minimal lexical rescue: keep clearly term-matching candidates when semantic score is low.
            if not filtered_by_score and pre_stage_results and query_words:
                lexical_hits = []
                for r in pre_stage_results:
                    chunk_text = str(r.get("text", "")).lower()
                    hit_count = sum(1 for kw in query_words if kw in chunk_text)
                    if hit_count > 0:
                        lexical_hits.append((hit_count, r))
                if lexical_hits:
                    lexical_hits.sort(key=lambda x: x[0], reverse=True)
                    filtered_by_score = [r for _, r in lexical_hits[:max(2, min(4, len(lexical_hits)))]]

            final_results = filtered_by_score
            if not final_results:
                print(f"[LiveRAGManager] Stage-A Guard: no sufficiently relevant chunks (mild_cutoff={mild_cutoff:.2f}) for query '{query}'. Treating as NO DOCS.")
                if return_dicts: return []
                return []

            # Coverage guard for weak/partial evidence before Stage-B.
            total_filtered_text_len = sum(len(str(r.get("text", ""))) for r in final_results)
            strong_chunks = sum(
                1
                for r in final_results
                if _safe_float(r.get("similarity", r.get("score", 0.0))) >= max(mild_cutoff, 0.18)
                and len(str(r.get("text", "")).strip()) >= 80
            )
            min_strong_required = 1
            if (not is_paragraph) and strong_chunks < min_strong_required and total_filtered_text_len < 800:
                print(
                    f"[LiveRAGManager] Coverage Guard: insufficient evidence "
                    f"(strong_chunks={strong_chunks}, total_context_chars={total_filtered_text_len}). "
                    f"Treating as NO DOCS."
                )
                if return_dicts: return []
                return []

            # c) Process/factual guard for "steps/process" intents
            process_intent = any(w in q_lower for w in ["steps", "process", "procedure", "how to", "phases"])
            if process_intent:
                # Require multiple chunks + explicit process language for procedural answers.
                if len(final_results) < 2:
                    print(f"[LiveRAGManager] Process Guard: Sub-threshold context volume for process query. Treating as NO DOCS.")
                    if return_dicts: return []
                    return []
                
                # Verify that context actually touches on steps/process
                has_process_words = False
                for r in final_results:
                    txt = str(r.get("text", "")).lower()
                    if any(w in txt for w in ["step", "process", "stage", "phase", "first", "second", "then", "procedure"]):
                        has_process_words = True
                        break
                if not has_process_words:
                    print(f"[LiveRAGManager] Process Guard: Context lacks process-related keywords. Treating as NO DOCS.")
                    if return_dicts: return []
                    return []

            # Stage B (keyword/semantic consistency): allow in-domain matches even if < strict_cutoff.
            if query_words:
                has_keyword_match = False
                concept_synonyms = {
                    "goals": ["goal", "goals", "objective", "objectives"],
                    "management": ["management", "managerial"],
                    "organization": ["organization", "organizing", "organisational", "organizational"],
                    "planning": ["planning", "plan", "plans"],
                    "scientific": ["scientific", "science", "taylor"],
                }
                for r in final_results:
                    chunk_text = str(r.get("text", "")).lower()
                    if any(
                        (kw in chunk_text) or any(s in chunk_text for s in concept_synonyms.get(kw, []))
                        for kw in query_words
                    ):
                        has_keyword_match = True
                        break
                
                if not has_keyword_match:
                    print(f"[LiveRAGManager] Strict Guard: None of the target chunks contained query keywords {query_words}. Treating as NO DOCS.")
                    if return_dicts: return []
                    return []

        if is_compare:
            compare_concepts = query_style.get("compare_concepts") or []
            if len(compare_concepts) == 2:
                a = compare_concepts[0].lower()
                b = compare_concepts[1].lower()
                support_a = any(a in str(r.get("text", "")).lower() for r in final_results)
                support_b = any(b in str(r.get("text", "")).lower() for r in final_results)
                if not (support_a and support_b):
                    print(f"[LiveRAGManager] Compare Guard: missing evidence for both concepts ({compare_concepts}). Treating as NO DOCS.")
                    if return_dicts:
                        return []
                    return []

        final_results.sort(key=lambda x: (
            -_safe_float(x.get("similarity", x.get("score", 0.0))),
            str((x.get("metadata") or {}).get("source", "")),
            str((x.get("metadata") or {}).get("section", "")),
            _safe_int((x.get("metadata") or {}).get("page", 0)),
            _safe_int((x.get("metadata") or {}).get("chunk_index", 0)),
            str(x.get("id", ""))
        ))

        for idx, r in enumerate(final_results):
            score = r.get("score", "N/A")
            meta = r.get("metadata", {})
            score_str = f"{score:.4f}" if isinstance(score, float) else str(score)
            print(f"  [{idx}] unit={meta.get('unit', 'None')}, section={meta.get('section', 'None')}, page={meta.get('page', 'None')}, score={score_str}, len={len(r.get('text', ''))}")
            
        if return_dicts:
            return final_results
            
        return [r["text"] for r in final_results]

# Inject the new pipeline wrapper
live_rag = LiveRAGManager()

# Shared lock to serialize heavy RAG operations and prevent laptop CPU/GPU overload
_rag_lock = asyncio.Lock()
_rag_cache = {}

async def _async_rag_search(*args, **kwargs):
    import asyncio
    from functools import partial
    import hashlib
    import json
    
    # Create simple cache key from args
    try:
        cache_key = hashlib.md5(json.dumps({'args': args, 'kwargs': kwargs}, sort_keys=True).encode()).hexdigest()
        if cache_key in _rag_cache:
            return _rag_cache[cache_key]
    except Exception:
        cache_key = None
        
    loop = asyncio.get_event_loop()
    func = partial(live_rag.search, *args, **kwargs)
    
    # Ensure only 1 RAG search runs at a time to save laptop resources
    async with _rag_lock:
        result = await loop.run_in_executor(None, func)
        if cache_key:
            _rag_cache[cache_key] = result
            # keep cache small
            if len(_rag_cache) > 100:
                _rag_cache.pop(next(iter(_rag_cache)))
        return result

@app.on_event("startup")
async def startup_event():
    global llm_session, tts_session, whisper_model, whisper_model_multilingual, xtts_model, WHISPER_DEVICE, WHISPER_COMPUTE_TYPE
    
    init_database()
    init_analytics_db()
    
    # Create persistent session for LLM requests with connection pooling
    connector = aiohttp.TCPConnector(
        limit=10,
        limit_per_host=5,
        ttl_dns_cache=300,
        force_close=False,
        enable_cleanup_closed=True
    )
    timeout = aiohttp.ClientTimeout(total=180, connect=5, sock_read=60)
    llm_session = aiohttp.ClientSession(
        connector=connector,
        timeout=timeout,
        headers={'Connection': 'keep-alive'}
    )

    # Create persistent session for TTS requests — avoids TCP handshake on
    # every query (XTTS microservice on localhost:5002).
    tts_connector = aiohttp.TCPConnector(
        limit=4,
        limit_per_host=2,
        force_close=False,
        enable_cleanup_closed=True,
    )
    tts_session = aiohttp.ClientSession(
        connector=tts_connector,
        timeout=aiohttp.ClientTimeout(total=None, sock_connect=5, sock_read=None),
        headers={'Connection': 'keep-alive'},
    )

    logger.info("✓ Databases ready")
    logger.info(
        f"[RAG Startup] file={Path(__file__).resolve()} | "
        f"python={sys.executable} | guard_mode={RAG_GUARD_MODE_VERSION}"
    )

    # ================== NEW PIPELINE STARTUP LOGS ==================
    logger.info("\n========== RAG PIPELINE DIAGNOSTICS ==========")
    logger.info(f"Active Retrieval Class/Module: {live_rag.vs.__class__.__module__}.{live_rag.vs.__class__.__name__}")
    db_path = str(Path(__file__).resolve().parent / 'chroma_db_v3')
    logger.info(f"Active ChromaDB Path: {db_path}")
    if live_rag.vs.collection:
        logger.info(f"Active Collection Name: {live_rag.vs.collection.name}")
        total_chunks = live_rag.vs.collection.count()
        logger.info(f"Number of chunks loaded: {total_chunks}")
        try:
            sample_query = "Main concepts"
            logger.info(f"\n--- STARTUP DEBUG TEST: '{sample_query}' ---")
            debug_results = live_rag.vs.search(query=sample_query, top_k=3, threshold=-2.0)
            for i, res in enumerate(debug_results, start=1):
                logger.info(f"Result #{i} | Sim: {res['similarity']:.4f} | Meta: {res['metadata']}")
                logger.info(f"Preview: {res['text'][:150].replace(chr(10), ' ') if res['text'] else 'None'}")
            logger.info("=================================================\n")
        except Exception as e:
            logger.info(f"Startup debug test failed: {e}")

    logger.info("✓ Persistent LLM session created with connection pooling")
    logger.info("✓ Persistent TTS session created")
    
    # Initialize faster-whisper (GPU required)
    if not WHISPER_AVAILABLE:
        error_msg = "CRITICAL: faster-whisper not installed. Install with: pip install faster-whisper"
        logger.error(error_msg)
        raise ImportError(error_msg)
    
    if not torch.cuda.is_available() and WHISPER_DEVICE == "cuda":
        logger.warning("CUDA not available for faster-whisper — falling back to CPU with int8 compute.")
        # Override device/compute to CPU-compatible values so the server can still start
        WHISPER_DEVICE = "cpu"
        WHISPER_COMPUTE_TYPE = "int8"
    
    logger.info(f"Loading faster-whisper model '{WHISPER_MODEL_SIZE}' on {WHISPER_DEVICE}...")
    logger.info(f"Model path: {WHISPER_MODEL_PATH}")
    
    try:
        # Load model from local directory
        if WHISPER_MODEL_PATH.exists():
            logger.info(f"Using local model from: {WHISPER_MODEL_PATH}")
            whisper_model = WhisperModel(
                str(WHISPER_MODEL_PATH),
                device=WHISPER_DEVICE,
                compute_type=WHISPER_COMPUTE_TYPE,
                download_root=None  # Don't download, use local only
            )
        else:
            # Download model to specified directory
            logger.info(f"Downloading model '{WHISPER_MODEL_SIZE}' to: {WHISPER_MODEL_PATH}")
            WHISPER_MODEL_PATH.parent.mkdir(parents=True, exist_ok=True)
            whisper_model = WhisperModel(
                WHISPER_MODEL_SIZE,
                device=WHISPER_DEVICE,
                compute_type=WHISPER_COMPUTE_TYPE,
                download_root=str(WHISPER_MODEL_PATH.parent)
            )
        
        logger.info(f"✓ faster-whisper loaded successfully")
        logger.info(f"  Device: {WHISPER_DEVICE}")
        logger.info(f"  Compute type: {WHISPER_COMPUTE_TYPE}")
        logger.info(f"  Beam size: {WHISPER_BEAM_SIZE}")
        logger.info(f"  VAD filter: {WHISPER_VAD_FILTER}")
        
    except Exception as e:
        error_msg = f"CRITICAL: Failed to load faster-whisper: {e}"
        logger.error(error_msg)
        raise RuntimeError(error_msg)

    # XTTS v2 runs as a separate microservice — check it is reachable
    import urllib.request
    try:
        req = urllib.request.urlopen(f"{XTTS_SERVICE_URL}/health", timeout=5)
        health = req.read().decode()
        logger.info(f"XTTS microservice reachable: {health[:80]}")
        xtts_model = True  # acts as a flag — True means service is up
    except Exception as e:
        logger.warning(f"XTTS microservice not reachable at {XTTS_SERVICE_URL} — TTS unavailable. "
                       f"Start it with: start_xtts_service.bat  ({e})")
        xtts_model = None

    # ---- Try to load multilingual faster-whisper model for Arabic STT ----
    # Resolution order:
    #   1. Direct folder  (faster-whisper-small/)        ← created by /arabic/download or manual placement
    #   2. HF cache folder (models--Systran--faster-whisper-small/snapshots/<hash>/)  ← already present if
    #      the model was previously downloaded via huggingface_hub
    def _find_ml_model_path() -> Path | None:
        """Return the best available multilingual model path, or None."""
        # 1. Direct folder
        if _MULTILINGUAL_MODEL_PATH.exists() and any(_MULTILINGUAL_MODEL_PATH.iterdir()):
            return _MULTILINGUAL_MODEL_PATH
        # 2. HF cache format: Models/models--Systran--faster-whisper-small/snapshots/<hash>/
        _hf_cache = _MULTILINGUAL_MODEL_PATH.parent / "models--Systran--faster-whisper-small" / "snapshots"
        if _hf_cache.exists():
            _snaps = sorted(_hf_cache.iterdir())
            if _snaps:
                return _snaps[-1]   # latest snapshot
        return None

    _ml_resolved = _find_ml_model_path()
    if _ml_resolved:
        logger.info(f"Multilingual faster-whisper model found at {_ml_resolved} — loading for Arabic STT...")
        try:
            # IMPORTANT: Force CPU for multilingual model.
            # RTX 3070 Laptop (8 GB VRAM) is fully consumed by Ollama + XTTS.
            # Loading whisper on CUDA causes Ollama to be evicted → LLM timeouts.
            _ml_device  = "cpu"
            _ml_compute = "int8"
            _ml_kwargs: dict = {"device": _ml_device, "compute_type": _ml_compute, "download_root": None}
            import os as _os
            _cpu_threads = int(_os.getenv("WHISPER_CPU_THREADS", str(min(_os.cpu_count() or 4, 8))))
            _ml_kwargs.update({"cpu_threads": _cpu_threads, "num_workers": 1})
            whisper_model_multilingual = WhisperModel(str(_ml_resolved), **_ml_kwargs)
            logger.info(f"✓ Multilingual faster-whisper loaded (Arabic STT ready, device={_ml_device}, compute={_ml_compute})")
        except Exception as _ml_e:
            logger.warning(f"Multilingual model found but failed to load: {_ml_e} — Arabic STT will use English model as fallback")
    else:
        logger.info(f"Multilingual faster-whisper not found at {_MULTILINGUAL_MODEL_PATH} — Arabic STT download available via /arabic/download")

    # Fire-and-forget warmups — run in the background, invisible to users
    asyncio.create_task(_warmup_llm())
    asyncio.create_task(_warmup_xtts())

    # Assets watcher: prefer watchdog (OS events) for instant reindexing,
    # fallback to the polling watcher if watchdog isn't installed.
    try:
        from watchdog.observers import Observer
        from watchdog.events import FileSystemEventHandler

        # Capture the running event loop NOW (in the async context) so the
        # watchdog callbacks — which run in a separate OS thread — can safely
        # schedule coroutines without calling get_event_loop() from a thread
        # (which raises RuntimeError in Python 3.10+ when no loop is set for
        # that thread).
        _main_loop = asyncio.get_running_loop()

        class _AssetsHandler(FileSystemEventHandler):
            def on_created(self, event):
                if event.is_directory:
                    return
                try:
                    fname = Path(event.src_path).name
                    _main_loop.call_soon_threadsafe(
                                lambda f=fname: _queue_assets_reindex(f)
                    )
                except Exception:
                    logger.exception("Assets handler on_created error")

            def on_modified(self, event):
                if event.is_directory:
                    return
                try:
                    fname = Path(event.src_path).name
                    _main_loop.call_soon_threadsafe(
                        lambda f=fname: _queue_assets_reindex(f)
                    )
                except Exception:
                    logger.exception("Assets handler on_modified error")

        observer = Observer()
        observer.schedule(_AssetsHandler(), str(ASSETS_DIR), recursive=False)
        observer.daemon = True
        observer.start()
        app.state.assets_observer = observer
        logger.info("Assets watchdog started (watchdog installed)")
    except Exception:
        logger.info("watchdog not available — using polling assets watcher")
        asyncio.create_task(_assets_watcher())

    # If Chroma is empty but files exist in assets (e.g., after dependency/env
    # issues during earlier uploads), bootstrap indexing on startup.
    asyncio.create_task(_bootstrap_assets_index_if_needed())

async def _warmup_llm():
    """
    Background task: preload the Ollama model into VRAM on startup.

    Uses the official Ollama preload method: POST /api/generate with no
    prompt and keep_alive: -1.  This loads the model weights into GPU
    memory and tells Ollama to NEVER evict them, so every user query
    gets a fast first token instead of waiting 8+ seconds for a cold load.
    """
    await asyncio.sleep(3)          # let server finish binding first
    OLLAMA_BASE = f"http://{OLLAMA_HOST}:{OLLAMA_PORT}"
    preload_url = f"{OLLAMA_BASE}/api/generate"
    logger.info(f"[Warmup] Preloading {OLLAMA_MODEL} into VRAM (keep_alive=-1)...")
    payload = {
        "model": OLLAMA_MODEL,
        "keep_alive": -1,   # never evict from VRAM
        # No 'prompt' key — this is the official Ollama preload pattern.
        # Ollama loads the model and returns immediately without generating tokens.
        # IMPORTANT: num_ctx must match chat requests exactly, otherwise Ollama
        # reloads the model on every chat call (causing 8-second cold-start delays).
        "options": {
            "num_ctx": 3072,
            "num_gpu": 99,
        },
    }
    try:
        async with aiohttp.ClientSession() as session:
            async with session.post(
                preload_url,
                json=payload,
                timeout=aiohttp.ClientTimeout(total=120),
            ) as resp:
                if resp.status == 200:
                    logger.info(f"[Warmup] ✓ {OLLAMA_MODEL} loaded into VRAM | keep_alive=forever")
                else:
                    text = await resp.text()
                    logger.warning(f"[Warmup] Ollama preload returned {resp.status}: {text[:120]}")
    except Exception as e:
        logger.warning(f"[Warmup] LLM preload failed (Ollama may not be running yet): {e}")


async def _warmup_xtts():
    """Background task: warm up the XTTS model and pre-render the Arabic
    acknowledgment phrase so it can be streamed instantly on the first Arabic query.
    """
    global _arabic_ack_pcm, _arabic_offtopic_pcm
    await asyncio.sleep(10)  # let the XTTS service finish initializing
    logger.info(f"[Warmup] Sending TTS warmup request to {XTTS_SERVICE_URL}...")
    try:
        async with aiohttp.ClientSession() as session:
            # -- English warmup (keeps existing behaviour) --
            async with session.post(
                f"{XTTS_SERVICE_URL}/synthesize",
                json={"text": "test", "speaker": XTTS_SPEAKER, "language": XTTS_LANGUAGE},
                timeout=aiohttp.ClientTimeout(total=60),
            ) as resp:
                if resp.status == 200:
                    await resp.read()
                    logger.info("[Warmup] ✓ XTTS model warmed up")
                else:
                    text = await resp.text()
                    logger.warning(f"[Warmup] XTTS warmup returned {resp.status}: {text[:120]}")

            # -- Arabic acknowledgment + opener pre-render --
            # Synthesize ack phrase first (short, fast), then pre-render all 10
            # opener phrases in parallel so startup cost stays low.
            global _arabic_ack_pcm, _arabic_offtopic_pcm, _arabic_opener_pcm, _arabic_opener_pool
            _ACK_PHRASE = "تفضل"
            try:
                async with session.post(
                    f"{XTTS_SERVICE_URL}/synthesize",
                    json={"text": _ACK_PHRASE, "speaker": XTTS_SPEAKER, "language": "ar"},
                    timeout=aiohttp.ClientTimeout(total=60),
                ) as _ack_resp:
                    if _ack_resp.status == 200:
                        _wav = await _ack_resp.read()
                        _arabic_ack_pcm = _wav[44:] if len(_wav) > 44 else _wav
                        logger.info(f"[Warmup] ✓ Arabic ack audio cached ({len(_arabic_ack_pcm):,} bytes PCM)")
                    else:
                        logger.warning("[Warmup] Arabic ack pre-render failed")
            except Exception as _e_ack:
                logger.warning(f"[Warmup] Arabic ack pre-render error: {_e_ack}")

            # Pre-render all 10 opener phrases in parallel
            async def _render_opener_phrase(_sess, phrase: str) -> tuple:
                try:
                    async with _sess.post(
                        f"{XTTS_SERVICE_URL}/synthesize",
                        json={"text": phrase, "speaker": XTTS_SPEAKER, "language": "ar"},
                        timeout=aiohttp.ClientTimeout(total=60),
                    ) as _r:
                        if _r.status == 200:
                            _wav = await _r.read()
                            _pcm = _wav[44:] if len(_wav) > 44 else _wav
                            logger.info(f"[Warmup] ✓ Opener '{phrase[:25]}' cached ({len(_pcm):,} bytes PCM)")
                            return phrase, _pcm
                        else:
                            logger.warning(f"[Warmup] Opener '{phrase[:25]}' pre-render failed")
                except Exception as _e_op:
                    logger.warning(f"[Warmup] Opener '{phrase[:25]}' error: {_e_op}")
                return phrase, b""

            _opener_results = await asyncio.gather(
                *[_render_opener_phrase(session, p) for p in _ARABIC_OPENER_PHRASES]
            )
            for _ph, _pcm in _opener_results:
                if _pcm:
                    _arabic_opener_pool[_ph] = _pcm
            # Set default fallback to first phrase
            if _ARABIC_OPENER_PHRASES[0] in _arabic_opener_pool:
                _arabic_opener_pcm = _arabic_opener_pool[_ARABIC_OPENER_PHRASES[0]]
    except Exception as e:
        logger.warning(f"[Warmup] XTTS warmup failed (service may not be running): {e}")


@app.on_event("shutdown")
async def shutdown_event():
    global llm_session, tts_session
    if llm_session and not llm_session.closed:
        await llm_session.close()
        logger.info("✓ LLM session closed")
    if tts_session and not tts_session.closed:
        await tts_session.close()
        logger.info("✓ TTS session closed")

logger.info("Initializing Assistify RAG System with faster-whisper...")

# ---------------------------------------------------------------------------
# Assets watcher helpers (debounce + skip + per-file lock)
# ---------------------------------------------------------------------------

_assets_reindex_tasks: dict[str, asyncio.Task] = {}
_assets_recently_indexed_until: dict[str, float] = {}
_assets_reindex_locks: dict[str, asyncio.Lock] = defaultdict(asyncio.Lock)


def _should_skip_assets_reindex(filename: str) -> bool:
    """Return True if we should skip reindexing because the upload endpoint
    already indexed it (prevents double work from watchdog create/modify).
    """
    now = time.time()
    until = _assets_recently_indexed_until.get(filename)
    if until and now < until:
        return True
    return False


def _mark_assets_recently_indexed(filename: str, seconds: float = 120.0) -> None:
    _assets_recently_indexed_until[filename] = time.time() + seconds


def _queue_assets_reindex(filename: str, delay_s: float = 0.75) -> None:
    """Debounce reindex requests for the same filename."""
    if _should_skip_assets_reindex(filename):
        logger.info(f"Assets watcher: skip (recently indexed) — {filename}")
        return
    prev = _assets_reindex_tasks.get(filename)
    if prev and not prev.done():
        prev.cancel()
    _assets_reindex_tasks[filename] = asyncio.create_task(_debounced_reindex(filename, delay_s=delay_s))


async def _debounced_reindex(filename: str, delay_s: float = 0.75) -> None:
    await asyncio.sleep(delay_s)
    if _should_skip_assets_reindex(filename):
        return
    save_path = ASSETS_DIR / filename
    if not save_path.exists():
        return

    # Wait until file stops changing (Windows tends to fire created+modified)
    try:
        last = save_path.stat()
        for _ in range(3):
            await asyncio.sleep(0.35)
            cur = save_path.stat()
            if cur.st_size == last.st_size and cur.st_mtime == last.st_mtime:
                break
            last = cur
    except Exception:
        # If stat fails, just attempt reindex once
        pass

    async with _assets_reindex_locks[filename]:
        # Double-check skip inside the lock
        if _should_skip_assets_reindex(filename):
            return
        await _reindex_file_auto(filename)


def _extract_text_from_asset(save_path: Path) -> str:
    """Extract text from a .txt or .pdf asset.

    IMPORTANT: Never decode PDF bytes as UTF-8. That produces '%PDF-1.4' and
    'obj<</...>>' chunks which are not human text.
    """
    suffix = save_path.suffix.lower()
    if suffix == ".pdf":
        try:
            from PyPDF2 import PdfReader
            reader = PdfReader(save_path)
            pages: list[str] = []
            for page_num, p in enumerate(reader.pages, start=1):
                try:
                    page_text = p.extract_text() or ""
                    pages.append(f"[PAGE_START: {page_num}]\n{page_text}\n[PAGE_END: {page_num}]")
                except Exception:
                    pages.append(f"[PAGE_START: {page_num}]\n\n[PAGE_END: {page_num}]")
            return "\n\n".join(pages)
        except Exception as e:
            logger.warning(f"Assets watcher: PDF extraction failed for {save_path.name}: {e}")
            return ""

    # Default: treat as text file
    content = save_path.read_bytes()
    try:
        return content.decode("utf-8")
    except Exception:
        return content.decode(errors="ignore")


def _pick_verification_snippet(text: str) -> str:
    """Pick a reasonable human-ish line for verification search."""
    for line in (text or "").splitlines():
        s = line.strip()
        if not s:
            continue
        # Skip PDF headers / object dumps
        if s.startswith("%PDF") or " obj" in s or "<</" in s:
            continue
        if len(s) < 25:
            continue
        # Prefer lines with letters
        if any(ch.isalpha() for ch in s):
            return s[:120]
    # Fallback
    return (text.strip().replace("\n", " ")[:120]) if text else ""


async def _reindex_file_auto(filename: str):
    """Background helper to reindex a file by filename.

    Uses delete_documents_by_filename() to wipe ALL previous chunks for this
    file (including any orphaned chunks with a different doc_id prefix created
    during earlier buggy runs), then re-indexes with a stable doc_id.
    Verifies the new content is searchable after write.
    """
    try:
        save_path = ASSETS_DIR / filename
        if not save_path.exists():
            logger.warning(f"Assets watcher: file disappeared before reindex: {filename}")
            return
        text = _extract_text_from_asset(save_path)

        if not text.strip():
            logger.info(f"Assets watcher: skipping empty/unextractable file: {filename}")
            return

        # ---- STEP 1: delete ALL existing chunks for this filename ----
        deleted = delete_documents_by_filename(filename)
        logger.info(f"Assets watcher [{filename}]: deleted {deleted} old chunk(s)")

        # ---- STEP 2: build a stable doc_id from the filename itself ----
        # We do NOT reuse a DB-derived doc_id because we just deleted everything.
        # Using a deterministic prefix based on the filename makes future deletes
        # reliable even across server restarts.
        import re as _re
        bare = _re.sub(r'^[0-9a-fA-F]{8}_', '', filename)  # strip UUID prefix if any
        safe = _re.sub(r'[^A-Za-z0-9._-]', '_', bare)
        doc_id = f"upload_{safe}"
        metadata = {"source": "watcher", "filename": filename, "file_ext": save_path.suffix.lower()}

        added = chunk_and_add_document(doc_id=doc_id, text=text, metadata=metadata,
                                        kb_version=_kb_global_version + 1)
        logger.info(f"Assets watcher [{filename}]: indexed {added} new chunk(s) (doc_id={doc_id})")

        # Prevent immediate duplicate reindex triggers (created+modified)
        _mark_assets_recently_indexed(filename, seconds=30.0)

        # ---- STEP 3: invalidate all caches + broadcast KB event ----
        await invalidate_all_caches(action="reindex", filename=filename,
                                     chunks_added=added, chunks_deleted=deleted,
                                     triggered_by="watcher")

        # ---- STEP 4: verify the new content is searchable ----
        snippet = _pick_verification_snippet(text)
        verify = await _async_rag_search(snippet, top_k=1, distance_threshold=1.5) if snippet else []
        if verify:
            logger.info(f"Assets watcher [{filename}]: ✓ verification OK — search returns: {verify[0][:60]}...")
        else:
            logger.warning(f"Assets watcher [{filename}]: ✗ verification FAILED — search returned nothing for: {snippet[:80]}")
    except Exception as e:
        logger.exception(f"Assets watcher reindex failed for {filename}: {e}")


async def _assets_watcher(poll_interval: float = 5.0):
    """Simple polling watcher for the ASSETS_DIR; reindexes changed/new files.

    On the FIRST scan we only record mtimes — we do NOT reindex because the DB
    already contains the data from the original upload.  We only reindex when a
    file is genuinely modified AFTER the server started (mtime changed) or when
    a brand-new file appears that was not present during the first scan.
    """
    logger.info("Assets watcher started (polling every %.1fs)", poll_interval)
    seen: dict[str, float] = {}
    first_scan_done = False
    try:
        while True:
            try:
                if not ASSETS_DIR.exists():
                    await asyncio.sleep(poll_interval)
                    continue
                for p in ASSETS_DIR.iterdir():
                    if not p.is_file():
                        continue
                    if p.suffix.lower() not in (".txt", ".pdf", ".md"):
                        continue
                    mtime = p.stat().st_mtime
                    key = str(p.name)
                    prev = seen.get(key)

                    if not first_scan_done:
                        # First scan: just record mtime, don't reindex
                        seen[key] = mtime
                    elif prev is None:
                        # New file added after server started
                        seen[key] = mtime
                        logger.info("Assets watcher: new file detected: %s — reindexing", key)
                        _queue_assets_reindex(key)
                    elif mtime != prev:
                        # Existing file was modified
                        seen[key] = mtime
                        logger.info("Assets watcher: file modified: %s — reindexing", key)
                        _queue_assets_reindex(key)

                if not first_scan_done:
                    first_scan_done = True
                    logger.info("Assets watcher: initial scan done — tracking %d file(s)", len(seen))

                # Remove deleted files from seen
                for key in list(seen.keys()):
                    if not (ASSETS_DIR / key).exists():
                        logger.info("Assets watcher: file removed: %s", key)
                        del seen[key]

            except Exception as e:
                logger.exception(f"Assets watcher loop error: {e}")
            await asyncio.sleep(poll_interval)
    except asyncio.CancelledError:
        logger.info("Assets watcher cancelled; shutting down")


async def _bootstrap_assets_index_if_needed() -> None:
    """Index existing asset files on startup when KB is empty.

    This prevents the system from answering with "knowledge base is empty"
    after restarts if files are present but were never successfully indexed.
    """
    await asyncio.sleep(1.0)
    try:
        existing_assets = [
            p.name for p in ASSETS_DIR.iterdir()
            if p.is_file() and p.suffix.lower() in (".txt", ".pdf", ".md")
        ]
        if not existing_assets:
            logger.info("KB bootstrap: no asset files found")
            return

        indexed_count = count_documents()
        if indexed_count > 0:
            logger.info("KB bootstrap: skip (already indexed chunks=%d)", indexed_count)
            return

        logger.warning(
            "KB bootstrap: detected %d asset file(s) with empty index; rebuilding now",
            len(existing_assets),
        )

        for filename in existing_assets:
            await _reindex_file_auto(filename)

        logger.info("KB bootstrap complete: indexed chunks=%d", count_documents())
    except Exception as e:
        logger.exception("KB bootstrap failed: %s", e)


