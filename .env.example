# ==================================================
# ENVIRONMENT CONFIGURATION
# ==================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env file to version control!

# Environment mode: "development" or "production"
ENVIRONMENT=development

# ==================================================
# SESSION SECRET (REQUIRED IN PRODUCTION)
# ==================================================
# MUST be at least 64 bytes (128 hex characters) for production
# Generate using: python -c "import secrets; print(secrets.token_hex(64))"
# Or: openssl rand -hex 64
SESSION_SECRET=your_session_secret_here_must_be_at_least_64_bytes_128_hex_chars

# ==================================================
# GOOGLE OAUTH CREDENTIALS (REQUIRED IN PRODUCTION)
# ==================================================
# Get these from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ==================================================
# EMAILJS CREDENTIALS (REQUIRED IN PRODUCTION)
# ==================================================
# Get these from: https://www.emailjs.com/
EMAILJS_PUBLIC_KEY=your_emailjs_public_key_here
EMAILJS_PRIVATE_KEY=your_emailjs_private_key_here
EMAILJS_SERVICE_ID=your_emailjs_service_id_here
EMAILJS_TEMPLATE_ID=your_emailjs_template_id_here

# ==================================================
# SECURITY SETTINGS (OPTIONAL)
# ==================================================
# Enable HTTPS enforcement (set to "true" in production)
ENFORCE_HTTPS=false

# Allowed hosts (comma-separated, e.g., "localhost,yourdomain.com")
# Leave empty to allow all hosts
ALLOWED_HOSTS=

# ==================================================
# RATE LIMITING (OPTIONAL)
# ==================================================
# Number of login attempts per minute per IP
RATE_LIMIT_LOGIN=5

# Number of registration attempts per minute per IP
RATE_LIMIT_REGISTER=3

# Number of OTP verification attempts per minute per IP
RATE_LIMIT_OTP=3

# ==================================================
# PASSWORD HASHING (OPTIONAL)
# ==================================================
# Bcrypt rounds (higher = more secure but slower)
# Default: 12 (recommended for production)
BCRYPT_ROUNDS=12
