# ==================================================
# ENVIRONMENT CONFIGURATION
# ==================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env file to version control!

# Environment mode: "development" or "production"
ENVIRONMENT=development

# ==================================================
# SESSION SECRET (REQUIRED IN PRODUCTION)
# ==================================================
# MUST be at least 64 bytes (128 hex characters) for production
# Generate using: python -c "import secrets; print(secrets.token_hex(64))"
# Or: openssl rand -hex 64
SESSION_SECRET=your_session_secret_here_must_be_at_least_64_bytes_128_hex_chars

# ==================================================
# GOOGLE OAUTH CREDENTIALS (REQUIRED IN PRODUCTION)
# ==================================================
# Get these from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ==================================================
# EMAILJS CREDENTIALS (REQUIRED IN PRODUCTION)
# ==================================================
# Get these from: https://www.emailjs.com/
EMAILJS_PUBLIC_KEY=your_emailjs_public_key_here
EMAILJS_PRIVATE_KEY=your_emailjs_private_key_here
EMAILJS_SERVICE_ID=your_emailjs_service_id_here
EMAILJS_TEMPLATE_ID=your_emailjs_template_id_here

# ==================================================
# SECURITY SETTINGS (OPTIONAL)
# ==================================================
# Enable HTTPS enforcement (set to "true" in production)
ENFORCE_HTTPS=false

# Allowed hosts (comma-separated, e.g., "localhost,yourdomain.com")
# Leave empty to allow all hosts
ALLOWED_HOSTS=

# ==================================================
# RATE LIMITING (OPTIONAL)
# ==================================================
# Number of login attempts per minute per IP
RATE_LIMIT_LOGIN=5

# Number of registration attempts per minute per IP
RATE_LIMIT_REGISTER=3

# Number of OTP verification attempts per minute per IP
RATE_LIMIT_OTP=3

# ==================================================
# PASSWORD HASHING (OPTIONAL)
# ==================================================
# Bcrypt rounds (higher = more secure but slower)
# Default: 12 (recommended for production)
BCRYPT_ROUNDS=12

# ==================================================
# LOCAL DEV (Assistify)
# ==================================================
OLLAMA_MODEL=qwen2.5:7b
# Prevents OpenMP duplicate-library crashes (torch + faster-whisper on Windows)
KMP_DUPLICATE_LIB_OK=TRUE
LLM_SERVER_PORT=8010
LLM_SERVER_URL=http://127.0.0.1:8010

# Skip EmailJS OTP on registration (development only — ignored when ENVIRONMENT=production)
SKIP_EMAIL_OTP=true

# Allow username==password dev logins when password hash is missing (development only)
ALLOW_DEV_LOGIN_FALLBACK=true

# Public customer chat at /frontend/guest/ without login (default on in development)
ALLOW_PUBLIC_GUEST_CHAT=true

# Login-server proxy timeout (seconds) when polling RAG /kb_status during heavy indexing
# KB_STATUS_PROXY_TIMEOUT_S=60

# Require tenant membership for chat/RAG (auto-on when ENVIRONMENT=production)
# ENFORCE_CHAT_TENANT_MEMBERSHIP=false

# Hybrid query prep before RAG: strip greetings, optional LLM normalize, KB typo fix
RAG_QUERY_LLM_PREP=true
